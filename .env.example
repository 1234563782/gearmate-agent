POSTGRES_DATABASE=gearmate
POSTGRES_USER=gearmate
POSTGRES_PASSWORD=replace-with-local-password
POSTGRES_PORT=5432

GEARMATE_ENVIRONMENT=development
GEARMATE_DATABASE_URL=postgresql+asyncpg://gearmate:replace-with-local-password@localhost:5432/gearmate
GEARMATE_RENTFLOW_BASE_URL=http://localhost:8080
GEARMATE_RENTFLOW_CONNECT_TIMEOUT_SECONDS=5
GEARMATE_RENTFLOW_READ_TIMEOUT_SECONDS=20
GEARMATE_TOOL_TIMEOUT_SECONDS=30
GEARMATE_JWT_PUBLIC_KEY_PATH=
GEARMATE_JWT_ISSUER=rentflow-server
GEARMATE_JWT_AUDIENCE=rentflow-platform
GEARMATE_CORS_ALLOWED_ORIGINS=http://localhost:5173

GEARMATE_MODEL_PROVIDER=openai-compatible
GEARMATE_MODEL_BASE_URL=
GEARMATE_MODEL_ID=
GEARMATE_MODEL_API_KEY=
GEARMATE_MODEL_CONNECT_TIMEOUT_SECONDS=5
GEARMATE_MODEL_FIRST_TOKEN_TIMEOUT_SECONDS=30
GEARMATE_MODEL_REQUEST_TIMEOUT_SECONDS=120
GEARMATE_MODEL_MAX_OUTPUT_TOKENS=4096
GEARMATE_RUN_TIMEOUT_SECONDS=180
GEARMATE_MAX_MODEL_ROUNDS=6
GEARMATE_MAX_TOOL_CALLS=10
GEARMATE_MAX_TOOL_CONCURRENCY=4
GEARMATE_MAX_TOOL_RESULT_ITEMS=20
GEARMATE_EVENT_POLL_INTERVAL_SECONDS=0.5
GEARMATE_SSE_HEARTBEAT_SECONDS=15
GEARMATE_CONTEXT_HISTORY_TOKEN_BUDGET=12000
GEARMATE_CONTEXT_SUMMARY_TRIGGER_TOKENS=8000
GEARMATE_CONTEXT_SUMMARY_MAX_OUTPUT_TOKENS=1024
GEARMATE_CONTEXT_RECENT_MESSAGES=8
GEARMATE_CONTEXT_SOURCE_MESSAGE_LIMIT=100
GEARMATE_RENTAL_PERIOD_EXTRACTION_MAX_OUTPUT_TOKENS=512
